{
  "name": "@techitwinner/web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "frontend:pkg": "pnpm install --filter=@techitwinner/web-frontend",
    "frontend:dev": "pnpm exec turbo run dev --filter=@techitwinner/web-frontend",
    "frontend:build": "pnpm exec turbo run build --filter=@techitwinner/web-frontend",
    "frontend:start": "pnpm exec turbo run start --filter=@techitwinner/web-frontend",
    "backend:windows":  "pnpm exec code/backend/pocketbase.exe serve --http localhost:3002",
    "backend:linux":  "pnpm exec code/backend/pocketbase serve --http localhost:3002"
  },
  "devDependencies": {
    "prettier": "^3.3.2",
    "turbo": "^2.2.3"
  },
  "packageManager": "pnpm@10.0.0",
  "prettier": {
    "printWidth": 100,
    "semi": false,
    "singleQuote": true,
    "endOfLine": "auto"
  }
}
