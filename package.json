{
  "name": "@techitwinner/web",
  "version": "13.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm exec turbo run dev",
    "build": "pnpm exec turbo run build",
    "start": "pnpm exec turbo run start",
    "deploy": "pnpm exec turbo run deploy",
    "frontend:pkg": "pnpm install --filter=@techitwinner/web-frontend",
    "frontend:dev": "pnpm dev --filter=@techitwinner/web-frontend",
    "frontend:build": "pnpm build --filter=@techitwinner/web-frontend",
    "frontend:start": "pnpm start --filter=@techitwinner/web-frontend",
    "backend:pkg": "pnpm install --filter=@techitwinner/web-backend",
    "backend:dev":  "pnpm dev --filter=@techitwinner/web-backend",
    "backend:build":  "pnpm build --filter=@techitwinner/web-backend",
    "backend:deploy":  "pnpm deploy --filter=@techitwinner/web-backend"
  },
  "devDependencies": {
    "prettier": "^3.3.2",
    "turbo": "^2.2.3"
  },
  "packageManager": "pnpm@10.0.0",
  "prettier": {
    "printWidth": 100,
    "semi": false,
    "singleQuote": true,
    "endOfLine": "auto"
  }
}
